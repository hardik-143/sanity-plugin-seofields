{
  "name": "sanity-plugin-seofields",
  "version": "1.2.6",
  "description": "A Sanity Studio plugin to manage SEO fields like meta titles, descriptions, and Open Graph tags for structured, search-optimized content.",
  "keywords": [
    "sanity",
    "sanity-plugin",
    "seo",
    "meta",
    "open graph",
    "social media",
    "content management",
    "structured data",
    "search engine optimization"
  ],
  "license": "MIT",
  "author": "Desai Hardik <dhardik1430@gmail.com>",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "source": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "source": "./src/next.ts",
      "import": "./dist/next.js",
      "require": "./dist/next.cjs"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "next": [
        "./dist/next.d.ts"
      ]
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "watch": "tsup --watch",
    "link-watch": "plugin-kit link-watch",
    "format": "prettier --write --cache --ignore-unknown .",
    "lint": "eslint .",
    "prepublishOnly": "npm run build",
    "generate-schema": "npx tsx schema-generator.ts",
    "typecheck": "tsc --noEmit"
  },
  "sanityPlugin": {
    "linkWatch": {
      "command": "pnpm run watch"
    },
    "verifyPackage": {
      "pkg-utils": false,
      "scripts": false,
      "tsconfig": false,
      "sanityV2Json": false,
      "eslintImports": false
    }
  },
  "dependencies": {
    "@sanity/incompatible-plugin": "^1.0.5",
    "@sanity/ui": "^3.1.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hardik-143/sanity-plugin-seofields.git"
  },
  "devDependencies": {
    "@sanity/codegen": "^4.9.0",
    "@sanity/plugin-kit": "^4.0.20",
    "@types/react": "^19.1.13",
    "@typescript-eslint/eslint-plugin": "^8.44.0",
    "@typescript-eslint/parser": "^8.44.0",
    "baseline-browser-mapping": "^2.10.8",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-sanity": "^7.1.4",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "prettier": "^3.6.2",
    "prettier-plugin-packagejson": "^2.5.19",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "sanity": "^4.10.0",
    "styled-components": "^6.1.19",
    "ts-json-schema-generator": "^2.4.0",
    "tsup": "^8.0.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "sanity": "^3 || ^4"
  },
  "engines": {
    "node": ">=18"
  }
}
